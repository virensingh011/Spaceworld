body {
  margin: 0;
  font-family: Arial;
  background: black;
  color: white;
  text-align: center;
}

header {
  padding: 20px;
}

.card {
  background: rgba(255,255,255,0.05);
  margin: 20px;
  padding: 20px;
  border-radius: 10px;
  backdrop-filter: blur(10px);
}

/* stars animation */
.stars {
  width: 100%;
  height: 100%;
  background: url('https://www.transparenttextures.com/patterns/stardust.png');
  position: fixed;
  z-index: -1;
}
